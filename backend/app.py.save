@app.route('/api/tips', methods=['GET'])
def get_tips():
    category = request.args.get('category', None)
    if category and category != 'All':
        filtered = [t for t in TIPS if t['category'] == category]
        return jsonify(filtered)
    return jsonify(TIPS)

@app.route('/api/quiz', methods=['GET'])
def get_quiz():
    return jsonify(QUIZ_QUESTIONS)

@app.route('/api/quiz/check', methods=['POST'])
def check_quiz():
    data = request.get_json()
    question_id = data.get('question_id')
    selected = data.get('selected')
    is_final = data.get('is_final', False)
    final_score = data.get('final_score', None)
    total_questions = data.get('total_questions', None)

    question = next((q for q in QUIZ_QUESTIONS if q['id'] == question_id), None)
    if not question:
        return jsonify({"error": "Question not found"}), 404

    correct = question['correct'] == selected


    # Save final score to database when quiz is complete
    if is_final and final_score is not None and total_questions is not None:
        percentage = (final_score / total_questions) * 100
        result = QuizResult(
            score=final_score,
            total=total_questions,
            percentage=percentage
        )
        db.session.add(result)
        db.session.commit()

    return jsonify({
        "correct": correct,
        "correct_answer": question['correct'],
        "explanation": question['explanation']
    })

# ── PORT SCANNER ───────────────────────────────────────────

import socket
import concurrent.futures

COMMON_PORTS = [
    {"port": 21,   "service": "FTP",        "risk": "Medium", "description": "File Transfer Protocol. If open and not needed, close it — attackers use it to upload malicious files."},
    {"port": 22,   "service": "SSH",         "risk": "Low",    "description": "Secure Shell. Used for remote server access. Make sure it uses strong passwords or key-based authentication."},
    {"port": 23,   "service": "Telnet",      "risk": "High",   "description": "Very old and insecure remote access protocol. Should NEVER be open — all data is sent unencrypted."},
    {"port": 25,   "service": "SMTP",        "risk": "Medium", "description": "Email sending protocol. If open on a personal device, it could be used to send spam."},
    {"port": 53,   "service": "DNS",         "risk": "Low",    "description": "Domain Name System. Translates domain names to IP addresses. Usually safe but can be exploited."},
    {"port": 80,   "service": "HTTP",        "risk": "Low",    "description": "Standard web traffic. Open on web servers. Prefer HTTPS (443) for secure browsing."},
    {"port": 110,  "service": "POP3",        "risk": "Medium", "description": "Email receiving protocol. Older and less secure than IMAP."},
    {"port": 135,  "service": "RPC",         "risk": "High",   "description": "Windows Remote Procedure Call. Commonly exploited by malware and ransomware."},
    {"port": 139,  "service": "NetBIOS",     "risk": "High",   "description": "Windows file sharing. Often exploited on local networks. Close if not needed."},
    {"port": 143,  "service": "IMAP",        "risk": "Medium", "description": "Email protocol for receiving messages. Should use encrypted version (993)."},
    {"port": 443,  "service": "HTTPS",       "risk": "Low",    "description": "Secure web traffic. This is the safe version of HTTP — good to see this open on web servers."},
    {"port": 445,  "service": "SMB",         "risk": "High",   "description": "Windows file sharing. Exploited by famous attacks like WannaCry ransomware. Close if not needed."},
    {"port": 3306, "service": "MySQL",       "risk": "High",   "description": "MySQL database. Should NEVER be exposed to the internet — keep it local only."},
    {"port": 3389, "service": "RDP",         "risk": "High",   "description": "Windows Remote Desktop. A top target for hackers. Should be closed or restricted if not in use."},
    {"port": 5432, "service": "PostgreSQL",  "risk": "High",   "description": "PostgreSQL database port. Like MySQL, should never be publicly accessible."},
    {"port": 8080, "service": "HTTP-Alt",    "risk": "Medium", "description": "Alternative HTTP port often used by web apps and proxies. Check what is running here."},
    {"port": 8443, "service": "HTTPS-Alt",   "risk": "Low",    "description": "Alternative HTTPS port. Usually safe but verify what service is using it."},
    {"port": 27017,"service": "MongoDB",     "risk": "High",   "description": "MongoDB database. Many data breaches happen because this port is left open to the internet."},
]

def scan_port(host, port, timeout=1):
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(timeout)
        result = sock.connect_ex((host, port))
        sock.close()
        return port, result == 0
    except Exception:
        return port, False

def resolve_host(target):
    try:
        ip = socket.gethostbyname(target)
        return ip, None
    except socket.gaierror:
        return None, "Could not resolve host. Please check the address and try again."

@app.route('/api/scan-ports', methods=['POST'])
def port_scan():
    data = request.get_json()
    target = data.get('target', '').strip()

    if not target:
        return jsonify({"error": "No target provided"}), 400

    # Security: only allow localhost and private IP ranges
    # This ensures the tool is used for self-education only
    allowed_targets = [
        'localhost', '127.0.0.1',
    ]

    # Resolve hostname to IP
    ip, error = resolve_host(target)
    if error:
        return jsonify({"error": error}), 400

    # Check if it's a private/local IP for safety
    import ipaddress
    try:
        ip_obj = ipaddress.ip_address(ip)
        is_private = (
            ip_obj.is_private or
            ip_obj.is_loopback or
            target in allowed_targets
        )
        if not is_private:
            return jsonify({
                "error": "For ethical and legal reasons, this tool only scans localhost and private network addresses. Enter '127.0.0.1' or 'localhost' to scan your own machine."
            }), 403
    except ValueError:
        return jsonify({"error": "Invalid IP address"}), 400

    # Scan ports concurrently for speed
    open_ports = []
    closed_ports = []

    ports_to_scan = [p["port"] for p in COMMON_PORTS]

    with concurrent.futures.ThreadPoolExecutor(max_workers=50) as executor:
        futures = {executor.submit(scan_port, ip, port): port for port in ports_to_scan}
        for future in concurrent.futures.as_completed(futures):
            port, is_open = future.result()
            port_info = next((p for p in COMMON_PORTS if p["port"] == port), None)
            if port_info:
                entry = {**port_info, "open": is_open}
                if is_open:
                    open_ports.append(entry)
                else:
                    closed_ports.append(entry)

    # Sort by port number
    open_ports.sort(key=lambda x: x["port"])
    closed_ports.sort(key=lambda x: x["port"])

    # Risk summary
    high_risk_open = [p for p in open_ports if p["risk"] == "High"]
    medium_risk_open = [p for p in open_ports if p["risk"] == "Medium"]

    if high_risk_open:
        overall = "Danger"
        overall_color = "#e74c3c"
        advice = f"{len(high_risk_open)} high-risk port(s) are open. Review and close them immediately."
    elif medium_risk_open:
        overall = "Caution"
        overall_color = "#f39c12"
        advice = f"{len(medium_risk_open)} medium-risk port(s) are open. Review whether they are needed."
    elif open_ports:
        overall = "Good"
        overall_color = "#2ecc71"
        advice = "Only low-risk ports are open. Your network exposure looks reasonable."
    else:
        overall = "Excellent"
        overall_color = "#2ecc71"
        advice = "No common ports are open. Your machine is well secured."

    return jsonify({
        "target": target,
        "ip": ip,
        "open_ports": open_ports,
        "closed_ports": closed_ports,
        "total_open": len(open_ports),
        "overall": overall,
        "overall_color": overall_color,
        "advice": advice,
        "high_risk_count": len(high_risk_open),
    })
@app.route('/api/stats', methods=['GET'])
def get_stats():
    total_passwords = PasswordCheck.query.count()
    total_phishing = PhishingCheck.query.count()
    total_quizzes = QuizResult.query.count()

    # Password strength breakdown
    strong = PasswordCheck.query.filter_by(strength="Strong").count()
    good = PasswordCheck.query.filter_by(strength="Good").count()
    fair = PasswordCheck.query.filter_by(strength="Fair").count()
    weak = PasswordCheck.query.filter_by(strength="Weak").count()
    very_weak = PasswordCheck.query.filter_by(strength="Very Weak").count()

    # Phishing verdicts breakdown
    dangerous = PhishingCheck.query.filter_by(verdict="Dangerous").count()
    likely_phishing = PhishingCheck.query.filter_by(verdict="Likely Phishing").count()
    suspicious = PhishingCheck.query.filter_by(verdict="Suspicious").count()
    safe = PhishingCheck.query.filter_by(verdict="Likely Safe").count()

    # Quiz average score
    all_quizzes = QuizResult.query.all()
    avg_score = round(sum(q.percentage for q in all_quizzes) / len(all_quizzes), 1) if all_quizzes else 0

    # Recent activity
    recent_passwords = [p.to_dict() for p in PasswordCheck.query.order_by(PasswordCheck.date_checked.desc()).limit(5).all()]
    recent_phishing = [p.to_dict() for p in PhishingCheck.query.order_by(PhishingCheck.date_checked.desc()).limit(5).all()]
    recent_quizzes = [q.to_dict() for q in QuizResult.query.order_by(QuizResult.date_taken.desc()).limit(5).all()]

    return jsonify({
        "totals": {
            "passwords_checked": total_passwords,
            "phishing_checked": total_phishing,
            "quizzes_taken": total_quizzes,
        },
        "password_breakdown": {
            "Strong": strong, "Good": good, "Fair": fair,
            "Weak": weak, "Very Weak": very_weak
        },
        "phishing_breakdown": {
            "Dangerous": dangerous, "Likely Phishing": likely_phishing,
            "Suspicious": suspicious, "Likely Safe": safe
        },
        "quiz_average": avg_score,
        "recent": {
            "passwords": recent_passwords,
            "phishing": recent_phishing,
            "quizzes": recent_quizzes
        }
    })

if __name__ == '__main__':
    app.run(debug=True, port=5000)
